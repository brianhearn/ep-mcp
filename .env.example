# Required: Embedding provider API key
GEMINI_API_KEY=your_gemini_api_key_here

# If using Azure OpenAI instead of Gemini
# AZURE_OPENAI_API_KEY=your_azure_openai_key_here

# Optional: Per-pack API key overrides (uppercase slug, hyphens→underscores)
# EP_MCP_KEY_MY_PACK=your_api_key_here

# Optional: Deploy target for scripts/deploy.sh
# EP_MCP_REMOTE_HOST=root@your-server-ip
# EP_MCP_REMOTE_SRC=/opt/ep-mcp/ep_mcp
# EP_MCP_REMOTE_SITE_PKG=/opt/ep-mcp/.venv/lib/python3.12/site-packages/ep_mcp
